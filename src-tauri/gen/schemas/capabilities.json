{
  "default": {
    "identifier": "default",
    "description": "FlowRename default capabilities",
    "local": true,
    "windows": ["main"],
    "permissions": [
      "core:default",
      "shell:allow-open",
      "dialog:default",
      "dialog:allow-open",
      "dialog:allow-save",
      "dialog:allow-message",
      "dialog:allow-ask",
      "dialog:allow-confirm",
      "core:window:allow-minimize",
      "core:window:allow-toggle-maximize",
      "core:window:allow-close",
      "core:window:allow-start-dragging"
    ]
  }
}
